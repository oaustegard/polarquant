"""NumPy-bit-compatible RNG: SeedSequence + PCG64 + Ziggurat standard_normal.

Layer-by-layer parity with NumPy 2.x's `np.random.default_rng(seed)`:
  1. SeedSequence — entropy hashing into a 4-uint32 pool, then mixing into
     uint64 state words via a deterministic XSHIFT routine.
  2. PCG64 — 128-bit state LCG with multiplier
     0x2360ED051FC65DA44385DF649FCCF645 and increment derived from the
     SeedSequence, output via XSL-RR (XOR shift low/high halves, rotate).
  3. Ziggurat — Doornik's 256-strip ziggurat for `standard_normal`, with
     the exact tables (`ki_double`, `wi_double`, `fi_double`) and tail/wedge
     arithmetic from `numpy/random/src/distributions/distributions.c::
     random_standard_normal` and `numpy/random/src/distributions/
     ziggurat_constants.h`.

This module exists alongside `src/rng.mojo` (xoshiro256++ + Marsaglia
polar). Both stay supported. The NumPy-compatible path is the new
default for `--seed`; the xoshiro path remains as `--rng xoshiro` for
fast self-contained workflows that don't need NumPy parity.

Verified against NumPy 2.4.4. The Ziggurat tail rejection arithmetic
uses libm `log1p`/`exp` — bit-identical across builds requires the same
libm. On the same Linux host these match; cross-host drift is possible
in principle for the rare tail samples (~0.7% of draws).
"""

from std.math import log1p, exp
from std.memory import alloc, UnsafePointer


# ---------------------------------------------------------------------------
# SeedSequence (NumPy 2.x compatible)
# ---------------------------------------------------------------------------

alias _SS_INIT_A     = UInt32(0x43B0D7E5)
alias _SS_MULT_A     = UInt32(0x931E8875)
alias _SS_INIT_B     = UInt32(0x8B51F9DD)
alias _SS_MULT_B     = UInt32(0x58F38DED)
alias _SS_MIX_MULT_L = UInt32(0xCA01F9DD)
alias _SS_MIX_MULT_R = UInt32(0x4973F715)
alias _SS_XSHIFT     = UInt32(16)
alias _SS_POOL_SIZE  = 4


fn _ss_hashmix(value_in: UInt32, mut hash_const: UInt32) -> UInt32:
    """Single-element hash mix matching NumPy's _hashmix."""
    var v = value_in ^ hash_const
    hash_const = hash_const * _SS_MULT_A
    v = v * hash_const
    v = v ^ (v >> _SS_XSHIFT)
    return v


fn _ss_mix(x: UInt32, y: UInt32) -> UInt32:
    """Combine two pool words matching NumPy's _mix."""
    var r = _SS_MIX_MULT_L * x - _SS_MIX_MULT_R * y
    r = r ^ (r >> _SS_XSHIFT)
    return r


fn seedseq_pool_from_u64(seed: UInt64) -> InlineArray[UInt32, 4]:
    """Build the 4-word pool for an integer seed.

    Decomposes seed into uint32 chunks little-endian (matches NumPy's
    `_int_to_uint32_array`): seeds < 2^32 give a single chunk; larger
    seeds give two chunks.
    """
    var entropy = InlineArray[UInt32, 2](fill=UInt32(0))
    var n_entropy: Int = 0
    if seed == 0:
        entropy[0] = UInt32(0)
        n_entropy = 1
    else:
        var s = seed
        while s > UInt64(0):
            entropy[n_entropy] = UInt32(s & UInt64(0xFFFFFFFF))
            s = s >> UInt64(32)
            n_entropy += 1
            if n_entropy >= 2:
                break

    var hash_const = _SS_INIT_A
    var pool = InlineArray[UInt32, 4](fill=UInt32(0))
    # Initial pool fill from entropy (zero-pad if shorter than pool size).
    for i in range(_SS_POOL_SIZE):
        var v: UInt32 = UInt32(0)
        if i < n_entropy:
            v = entropy[i]
        pool[i] = _ss_hashmix(v, hash_const)
    # All-pairs mixing across pool slots.
    for i_src in range(_SS_POOL_SIZE):
        for i_dst in range(_SS_POOL_SIZE):
            if i_src != i_dst:
                var hashed = _ss_hashmix(pool[i_src], hash_const)
                pool[i_dst] = _ss_mix(pool[i_dst], hashed)
    # Mix any extra entropy beyond the pool size into all slots.
    for i_src in range(_SS_POOL_SIZE, n_entropy):
        for i_dst in range(_SS_POOL_SIZE):
            var hashed = _ss_hashmix(entropy[i_src], hash_const)
            pool[i_dst] = _ss_mix(pool[i_dst], hashed)
    return pool


fn seedseq_generate_state_u64(pool: InlineArray[UInt32, 4],
                              n_words_u64: Int,
                              mut out: UnsafePointer[UInt64, MutExternalOrigin]):
    """Fill `out` with `n_words_u64` uint64 state words derived from `pool`.

    Matches NumPy's `SeedSequence.generate_state(n, dtype=uint64)`: each
    uint64 is two uint32 outputs concatenated little-endian (low-half
    first).
    """
    var hash_const = _SS_INIT_B
    var n_words_u32 = n_words_u64 * 2
    var src_cycle = _SS_POOL_SIZE
    var u32_buf = alloc[UInt32](n_words_u32)
    for i_dst in range(n_words_u32):
        var v = pool[i_dst % src_cycle]
        v = v ^ hash_const
        hash_const = hash_const * _SS_MULT_B
        v = v * hash_const
        v = v ^ (v >> _SS_XSHIFT)
        u32_buf[i_dst] = v
    for i in range(n_words_u64):
        var lo = UInt64(u32_buf[2 * i])
        var hi = UInt64(u32_buf[2 * i + 1])
        out[i] = lo | (hi << UInt64(32))
    u32_buf.free()


# ---------------------------------------------------------------------------
# PCG64 (XSL-RR, 128-bit state)
# ---------------------------------------------------------------------------

alias _PCG_MULT_HI = UInt64(0x2360ED051FC65DA4)
alias _PCG_MULT_LO = UInt64(0x4385DF649FCCF645)


fn _pcg_mult() -> UInt128:
    return (UInt128(_PCG_MULT_HI) << UInt128(64)) | UInt128(_PCG_MULT_LO)


fn _rotr64(x: UInt64, r: UInt64) -> UInt64:
    """Rotate x right by r bits."""
    var rr = r & UInt64(63)
    if rr == UInt64(0):
        return x
    return (x >> rr) | (x << (UInt64(64) - rr))


struct PCG64(Copyable, Movable):
    """NumPy-compatible PCG64 bit generator.

    State / inc are 128-bit. Output is XSL-RR: rotate-right of (low^high)
    by (high >> 58) bits. One step per output uint64.
    """
    var state: UInt128
    var inc: UInt128

    fn __init__(out self, seed: UInt64):
        """Initialize from an integer seed via SeedSequence."""
        var pool = seedseq_pool_from_u64(seed)
        var sw = alloc[UInt64](4)
        seedseq_generate_state_u64(pool, 4, sw)
        # NumPy treats sw[0..1] as the 128-bit initstate (high-word first)
        # and sw[2..3] as the 128-bit initseq.
        var initstate = (UInt128(sw[0]) << UInt128(64)) | UInt128(sw[1])
        var initseq   = (UInt128(sw[2]) << UInt128(64)) | UInt128(sw[3])
        sw.free()
        # pcg_setseq_128_srandom_r:
        #   inc   = (initseq << 1) | 1
        #   state = 0
        #   step                          # state becomes inc
        #   state += initstate
        #   step
        var mult = _pcg_mult()
        self.inc = (initseq << UInt128(1)) | UInt128(1)
        self.state = UInt128(0)
        self.state = self.state * mult + self.inc
        self.state = self.state + initstate
        self.state = self.state * mult + self.inc

    fn next_u64(mut self) -> UInt64:
        var mult = _pcg_mult()
        self.state = self.state * mult + self.inc
        var low  = UInt64(self.state & UInt128(0xFFFFFFFFFFFFFFFF))
        var high = UInt64((self.state >> UInt128(64)) & UInt128(0xFFFFFFFFFFFFFFFF))
        return _rotr64(high ^ low, high >> UInt64(58))

    fn next_double(mut self) -> Float64:
        # Standard NumPy convention: top 53 bits / 2^53.
        var u = self.next_u64()
        return Float64(u >> UInt64(11)) * (Float64(1.0) / Float64(1 << 53))


# ---------------------------------------------------------------------------
# Ziggurat standard_normal (256 strips, NumPy table values)
# ---------------------------------------------------------------------------

alias _ZIG_NOR_R     = Float64(3.6541528853610087963519472518)
alias _ZIG_NOR_INV_R = Float64(0.27366123732975827203338247596)


# Tables embedded from numpy/random/src/distributions/ziggurat_constants.h
# (NumPy v2.4.4). Builders run once per RNG instance.

