struct NumpyNormalRNG(Movable):
    """Ziggurat normal sampler driven by an embedded PCG64.

    `next_normal()` returns a Float64 sampled from N(0, 1) bit-identical
    to NumPy's `default_rng(seed).standard_normal()` (modulo libm
    log1p/exp variation in the tail-rejection branch — see module docstring).
    """
    var pcg: PCG64
    var ki: InlineArray[UInt64, 256]
    var wi: InlineArray[Float64, 256]
    var fi: InlineArray[Float64, 256]

    fn __init__(out self, seed: UInt64):
        self.pcg = PCG64(seed)
        self.ki = _build_ki()
        self.wi = _build_wi()
        self.fi = _build_fi()

    fn next_u64(mut self) -> UInt64:
        return self.pcg.next_u64()

    fn next_double(mut self) -> Float64:
        return self.pcg.next_double()

    fn next_normal(mut self) -> Float64:
        """Standard normal via Doornik's ziggurat. Mirrors
        `random_standard_normal` in NumPy's distributions.c byte-for-byte
        (modulo libm transcendental rounding in the tail branch).
        """
        while True:
            var r = self.pcg.next_u64()
            var idx = Int(r & UInt64(0xFF))
            r = r >> UInt64(8)
            var sign = Int(r & UInt64(1))
            var rabs = (r >> UInt64(1)) & UInt64(0x000FFFFFFFFFFFFF)
            var x = Float64(rabs) * self.wi[idx]
            if sign == 1:
                x = -x
            if rabs < self.ki[idx]:
                return x
            if idx == 0:
                # Tail (Marsaglia exponential rejection)
                while True:
                    var u1 = self.pcg.next_double()
                    var u2 = self.pcg.next_double()
                    var xx = -_ZIG_NOR_INV_R * log1p(-u1)
                    var yy = -log1p(-u2)
                    if yy + yy > xx * xx:
                        var sgn = (rabs >> UInt64(8)) & UInt64(1)
                        if sgn == UInt64(1):
                            return -(_ZIG_NOR_R + xx)
                        else:
                            return _ZIG_NOR_R + xx
            else:
                var u = self.pcg.next_double()
                var lhs = (self.fi[idx - 1] - self.fi[idx]) * u + self.fi[idx]
                if lhs < exp(-Float64(0.5) * x * x):
                    return x
        return Float64(0.0)  # unreachable
